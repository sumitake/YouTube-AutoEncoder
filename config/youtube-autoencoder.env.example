# YouTube AutoEncoder configuration.
# Copy this file to ~/.config/youtube-autoencoder/youtube-autoencoder.env
# and keep the real file private.

# Preferred direct source configuration.
# YTA_SOURCE_URL=rtsp://camera.example.local/stream1

# Optional OBS compatibility. Used for the YouTube RTMPS server/key and,
# when YTA_SOURCE_URL is not set, for the first matching VLC/RTSP source.
YTA_OBS_PROFILE_DIR=/home/encoder/.config/obs-studio/basic/profiles/YouTube_AutoEncoder
YTA_OBS_SERVICE_FILE=/home/encoder/.config/obs-studio/basic/profiles/YouTube_AutoEncoder/service.json
YTA_OBS_SCENE_FILE=/home/encoder/.config/obs-studio/basic/scenes/Untitled.json
# YTA_OBS_SOURCE_NAME=Camera RTSP

# copy = lowest CPU, preserves the camera's encoded H.264 stream.
# transcode = re-encode through FFmpeg before YouTube ingest.
YTA_MODE=copy

YTA_RTSP_TRANSPORT=tcp
YTA_RTSP_CONNECT_TIMEOUT_US=5000000
# Used by FFprobe only when the installed binary advertises this option.
YTA_RTSP_RW_TIMEOUT_US=15000000
YTA_MAX_RUNTIME=0
YTA_LOGLEVEL=info
YTA_FFMPEG_PROGRESS_INTERVAL_SEC=5
YTA_FFMPEG_PROGRESS_TIMEOUT_SEC=45

YTA_AUDIO_SAMPLE_RATE=48000
YTA_AUDIO_BITRATE=128k

# YouTube Live API lifecycle management.
YTA_YOUTUBE_LIFECYCLE=true
YTA_INSTANCE_ID=encoder-hostname
# Required for fail-safe pre-ingest staging; public visibility is applied only after live health gates.
YTA_YOUTUBE_STAGING_PRIVACY=unlisted
YTA_YOUTUBE_LIVE_PRIVACY=public
YTA_YOUTUBE_TITLE_PREFIX=AutoEncoder Live
YTA_YOUTUBE_POLL_INTERVAL_SEC=5
YTA_YOUTUBE_TRANSITION_TIMEOUT_SEC=180
YTA_YOUTUBE_LOCK_TIMEOUT_SEC=10
YTA_YOUTUBE_COMPLETE_ON_EXIT=false
YTA_YOUTUBE_API=/usr/local/bin/youtube-autoencoder-api

# Probe source before creating a YouTube broadcast.
YTA_SOURCE_PROBE=true
YTA_SOURCE_PROBE_TIMEOUT_SEC=12

# Used only when YTA_MODE=transcode.
YTA_TRANSCODE_ENCODER=libx264
YTA_TRANSCODE_SCALE=-2:720
YTA_FPS=30
YTA_GOP=60
YTA_VIDEO_BITRATE=4000k
YTA_VIDEO_MAXRATE=4000k
YTA_VIDEO_BUFSIZE=8000k
YTA_X264_PRESET=veryfast
