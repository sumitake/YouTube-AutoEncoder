"""YouTube Live API controller for YouTube AutoEncoder."""

from __future__ import annotations

import argparse
import contextlib
import datetime as dt
import fcntl
import json
import os
import pathlib
import re
import selectors
import signal
import socket
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request
import uuid
from typing import Any

HOME = pathlib.Path.home()
BASE_DIR = pathlib.Path(os.environ.get("YTA_CONFIG_DIR", HOME / ".config/youtube-autoencoder")).expanduser()
CLIENT_FILE = pathlib.Path(
    os.environ.get("YTA_YOUTUBE_CLIENT_FILE", BASE_DIR / "google-oauth-client.json")
).expanduser()
TOKEN_FILE = pathlib.Path(os.environ.get("YTA_YOUTUBE_TOKEN_FILE", BASE_DIR / "youtube-token.json")).expanduser()
STATE_FILE = pathlib.Path(os.environ.get("YTA_YOUTUBE_STATE_FILE", BASE_DIR / "youtube-live-state.json")).expanduser()
LOCK_FILE = pathlib.Path(os.environ.get("YTA_YOUTUBE_LOCK_FILE", BASE_DIR / "youtube-live-state.lock")).expanduser()
OBS_PROFILE_DIR = pathlib.Path(
    os.environ.get("YTA_OBS_PROFILE_DIR", HOME / ".config/obs-studio/basic/profiles/YouTube_AutoEncoder")
).expanduser()
OBS_SERVICE_FILE = pathlib.Path(os.environ.get("YTA_OBS_SERVICE_FILE", OBS_PROFILE_DIR / "service.json")).expanduser()
SCOPES = "https://www.googleapis.com/auth/youtube"
API_BASE = "https://www.googleapis.com/youtube/v3"

child: subprocess.Popen[Any] | None = None
stopping = False
RATE_LIMIT_REASONS = {
    "concurrentBroadcastsExceedLimit",
    "dailyLimitExceeded",
    "quotaExceeded",
    "rateLimitExceeded",
    "sharedIngestionBroadcastsExceedLimit",
    "userRateLimitExceeded",
    "userRequestsExceedRateLimit",
}
STATE_SCHEMA_VERSION = 2
RECOVERABLE_STATES = {"created", "ready", "testStarting", "testing", "liveStarting", "live"}
TERMINAL_STATES = {"complete", "revoked"}
KNOWN_LIFECYCLE_STATES = RECOVERABLE_STATES | TERMINAL_STATES
INSTANCE_MARKER_PREFIX = "youtube-autoencoder-instance"
GENERATION_MARKER_PREFIX = "youtube-autoencoder-generation"


class YouTubeApiError(RuntimeError):
    def __init__(
        self,
        *,
        status: int | None,
        reasons: tuple[str, ...],
        message: str,
        retry_after: float | None = None,
    ) -> None:
        super().__init__(message)
        self.status = status
        self.reasons = reasons
        self.retry_after = retry_after

    @property
    def retry_class(self) -> str:
        if self.status == 429 or any(reason in RATE_LIMIT_REASONS for reason in self.reasons):
            return "quota"
        if self.status is None or self.status >= 500:
            return "api"
        return "fatal"


class ReconciliationError(RuntimeError):
    retry_class = "ambiguous"


def log(message: str) -> None:
    print(f"{time.strftime('%Y-%m-%dT%H:%M:%S%z')} {message}", file=sys.stderr, flush=True)


def read_json(path: pathlib.Path) -> dict[str, Any]:
    with path.open("r", encoding="utf-8") as handle:
        data = json.load(handle)
    if not isinstance(data, dict):
        raise ValueError(f"{path} must contain a JSON object")
    return data


def fsync_directory(path: pathlib.Path) -> None:
    directory_fd = os.open(path, os.O_RDONLY)
    try:
        os.fsync(directory_fd)
    finally:
        os.close(directory_fd)


def write_json_durable(path: pathlib.Path, data: dict[str, Any], mode: int = 0o600) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    raw_fd, tmp_name = tempfile.mkstemp(
        prefix=f".{path.name}.",
        suffix=".tmp",
        dir=path.parent,
    )
    tmp = pathlib.Path(tmp_name)
    try:
        os.fchmod(raw_fd, mode)
        file_handle = os.fdopen(raw_fd, "w", encoding="utf-8")
        raw_fd = -1
        with file_handle as handle:
            json.dump(data, handle, indent=2, sort_keys=True)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        tmp.replace(path)
        os.chmod(path, mode)
        fsync_directory(path.parent)
    finally:
        if raw_fd >= 0:
            os.close(raw_fd)
        tmp.unlink(missing_ok=True)


def write_secret_json(path: pathlib.Path, data: dict[str, Any]) -> None:
    write_json_durable(path, data, mode=0o600)


def read_state() -> dict[str, Any]:
    if not STATE_FILE.exists():
        return {}
    try:
        return read_json(STATE_FILE)
    except (json.JSONDecodeError, ValueError):
        stamp = dt.datetime.now(dt.UTC).strftime("%Y%m%dT%H%M%SZ")
        corrupt = STATE_FILE.with_name(f"{STATE_FILE.name}.corrupt.{stamp}")
        STATE_FILE.replace(corrupt)
        fsync_directory(STATE_FILE.parent)
        log(f"quarantined corrupt lifecycle state at {corrupt}")
        return {}


@contextlib.contextmanager
def mutation_lock(timeout: float | None = None):
    LOCK_FILE.parent.mkdir(parents=True, exist_ok=True)
    with LOCK_FILE.open("a+", encoding="utf-8") as handle:
        os.chmod(LOCK_FILE, 0o600)
        deadline = None if timeout is None else time.monotonic() + timeout
        while True:
            try:
                fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
                break
            except BlockingIOError:
                if deadline is not None and time.monotonic() >= deadline:
                    raise TimeoutError(f"timed out acquiring mutation lock {LOCK_FILE}") from None
                time.sleep(0.05)
        handle.seek(0)
        handle.truncate()
        handle.write(f"pid={os.getpid()}\n")
        handle.flush()
        try:
            yield
        finally:
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


def error_payload(exc: BaseException) -> dict[str, Any]:
    if isinstance(exc, YouTubeApiError):
        return {
            "error": True,
            "http_status": exc.status,
            "message": str(exc),
            "reasons": list(exc.reasons),
            "retry_after": exc.retry_after,
            "retry_class": exc.retry_class,
        }
    retry_class = str(getattr(exc, "retry_class", "fatal"))
    return {
        "error": True,
        "http_status": None,
        "message": str(exc),
        "reasons": [],
        "retry_after": None,
        "retry_class": retry_class,
    }


def client_config() -> dict[str, str]:
    data = read_json(CLIENT_FILE)
    if "installed" in data:
        data = data["installed"]
    elif "web" in data:
        data = data["web"]
    client_id = str(data.get("client_id") or "")
    client_secret = str(data.get("client_secret") or "")
    if not client_id or not client_secret:
        raise ValueError(f"{CLIENT_FILE} must contain client_id and client_secret")
    return {"client_id": client_id, "client_secret": client_secret}


def http_json(
    method: str,
    url: str,
    *,
    token: str | None = None,
    form: dict[str, str] | None = None,
    body: dict[str, Any] | None = None,
) -> dict[str, Any]:
    headers: dict[str, str] = {"Accept": "application/json"}
    data: bytes | None = None
    if token:
        headers["Authorization"] = f"Bearer {token}"
    if form is not None:
        data = urllib.parse.urlencode(form).encode("utf-8")
        headers["Content-Type"] = "application/x-www-form-urlencoded"
    elif body is not None:
        data = json.dumps(body).encode("utf-8")
        headers["Content-Type"] = "application/json"

    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=30) as response:
            raw = response.read().decode("utf-8")
    except urllib.error.HTTPError as exc:
        raw = exc.read().decode("utf-8", errors="replace")
        try:
            parsed = json.loads(raw)
        except json.JSONDecodeError:
            parsed = {"error": raw}
        details = parsed.get("error") if isinstance(parsed, dict) else None
        details = details if isinstance(details, dict) else {}
        errors = details.get("errors") or []
        reasons = tuple(str(item.get("reason")) for item in errors if isinstance(item, dict) and item.get("reason"))
        message = str(details.get("message") or exc.reason or "YouTube API request failed")
        retry_after = None
        retry_after_value = exc.headers.get("Retry-After") if exc.headers else None
        if retry_after_value:
            try:
                retry_after = float(retry_after_value)
            except ValueError:
                # Retry-After is optional; malformed hints fall back to class-based backoff.
                retry_after = None
        raise YouTubeApiError(
            status=exc.code,
            reasons=reasons,
            message=message,
            retry_after=retry_after,
        ) from exc
    except (TimeoutError, urllib.error.URLError) as exc:
        raise YouTubeApiError(status=None, reasons=(), message=str(exc)) from exc
    if not raw:
        return {}
    parsed = json.loads(raw)
    if not isinstance(parsed, dict):
        raise RuntimeError(f"unexpected JSON response from {url}")
    return parsed


def authorize(_args: argparse.Namespace) -> int:
    cfg = client_config()
    device = http_json(
        "POST",
        "https://oauth2.googleapis.com/device/code",
        form={"client_id": cfg["client_id"], "scope": SCOPES},
    )
    print()
    print("Authorize YouTube AutoEncoder:")
    print(f"  Open: {device['verification_url']}")
    print(f"  Code: {device['user_code']}")
    print()
    print("Waiting for authorization...")

    interval = int(device.get("interval") or 5)
    expires_at = time.monotonic() + int(device.get("expires_in") or 1800)
    while time.monotonic() < expires_at:
        time.sleep(interval)
        try:
            token_data = http_json(
                "POST",
                "https://oauth2.googleapis.com/token",
                form={
                    "client_id": cfg["client_id"],
                    "client_secret": cfg["client_secret"],
                    "device_code": str(device["device_code"]),
                    "grant_type": "urn:ietf:params:oauth:grant-type:device_code",
                },
            )
        except RuntimeError as exc:
            text = str(exc)
            if "authorization_pending" in text:
                continue
            if "slow_down" in text:
                interval += 5
                continue
            raise
        token_data["created_at"] = int(time.time())
        write_secret_json(TOKEN_FILE, token_data)
        print(f"Saved token to {TOKEN_FILE}")
        return 0
    raise TimeoutError("OAuth device code expired before authorization completed")


def token() -> str:
    if not TOKEN_FILE.exists():
        raise FileNotFoundError("missing token file; run: youtube-autoencoder-api authorize")
    data = read_json(TOKEN_FILE)
    expires_at = int(data.get("created_at") or 0) + int(data.get("expires_in") or 0) - 120
    if data.get("access_token") and time.time() < expires_at:
        return str(data["access_token"])

    refresh_token = str(data.get("refresh_token") or "")
    if not refresh_token:
        raise ValueError("token file has no refresh_token; rerun authorization")
    cfg = client_config()
    refreshed = http_json(
        "POST",
        "https://oauth2.googleapis.com/token",
        form={
            "client_id": cfg["client_id"],
            "client_secret": cfg["client_secret"],
            "refresh_token": refresh_token,
            "grant_type": "refresh_token",
        },
    )
    data.update(refreshed)
    data["refresh_token"] = refresh_token
    data["created_at"] = int(time.time())
    write_secret_json(TOKEN_FILE, data)
    return str(data["access_token"])


def api(method: str, path: str, params: dict[str, str], body: dict[str, Any] | None = None) -> dict[str, Any]:
    query = urllib.parse.urlencode(params)
    return http_json(method, f"{API_BASE}{path}?{query}", token=token(), body=body)


def obs_stream_name() -> str:
    settings = read_json(OBS_SERVICE_FILE).get("settings") or {}
    stream_name = str(settings.get("key") or "")
    if not stream_name:
        raise ValueError(f"missing OBS stream key in {OBS_SERVICE_FILE}")
    return stream_name


def list_streams() -> list[dict[str, Any]]:
    data = api(
        "GET",
        "/liveStreams",
        {"part": "id,snippet,cdn,status,contentDetails", "mine": "true", "maxResults": "50"},
    )
    return list(data.get("items") or [])


def find_obs_stream() -> dict[str, Any]:
    stream_name = obs_stream_name()
    for stream in list_streams():
        ingestion = (stream.get("cdn") or {}).get("ingestionInfo") or {}
        if ingestion.get("streamName") == stream_name:
            return stream
    raise LookupError("no YouTube liveStream matched the configured OBS stream key")


def create_stream() -> dict[str, Any]:
    body = {
        "snippet": {
            "title": os.environ.get("YTA_YOUTUBE_STREAM_TITLE", "YouTube AutoEncoder Stream"),
            "description": "Reusable stream for YouTube AutoEncoder.",
        },
        "cdn": {
            "ingestionType": "rtmp",
            "resolution": os.environ.get("YTA_YOUTUBE_STREAM_RESOLUTION", "720p"),
            "frameRate": os.environ.get("YTA_YOUTUBE_STREAM_FRAMERATE", "30fps"),
        },
        "contentDetails": {"isReusable": True},
    }
    return api("POST", "/liveStreams", {"part": "snippet,cdn,contentDetails,status"}, body)


def save_stream_to_obs(stream: dict[str, Any]) -> None:
    ingestion = (stream.get("cdn") or {}).get("ingestionInfo") or {}
    stream_name = ingestion.get("streamName")
    server = ingestion.get("rtmpsIngestionAddress") or ingestion.get("ingestionAddress")
    if not stream_name or not server:
        raise ValueError("created stream did not return ingestion URL and stream name")
    service = read_json(OBS_SERVICE_FILE)
    service.setdefault("settings", {})
    service["settings"]["server"] = server
    service["settings"]["key"] = stream_name
    write_secret_json(OBS_SERVICE_FILE, service)


def ensure_stream(create_if_missing: bool = False) -> dict[str, Any]:
    try:
        return find_obs_stream()
    except LookupError:
        if not create_if_missing:
            raise
    stream = create_stream()
    save_stream_to_obs(stream)
    log("created reusable YouTube stream and updated OBS service.json")
    return stream


def instance_id() -> str:
    value = (os.environ.get("YTA_INSTANCE_ID") or socket.gethostname()).strip()
    if not value or not re.fullmatch(r"[A-Za-z0-9._-]+", value):
        raise ValueError("YTA_INSTANCE_ID must contain only letters, numbers, dot, underscore, and hyphen")
    return value


def instance_marker(instance: str) -> str:
    return f"[{INSTANCE_MARKER_PREFIX}:{instance}]"


def generation_marker(generation: str) -> str:
    return f"[{GENERATION_MARKER_PREFIX}:{generation}]"


def broadcast_description(instance: str, generation: str) -> str:
    return "\n".join(
        [
            "Managed by YouTube AutoEncoder.",
            "",
            instance_marker(instance),
            generation_marker(generation),
        ]
    )


def has_marker(broadcast: dict[str, Any], marker: str) -> bool:
    description = str((broadcast.get("snippet") or {}).get("description") or "")
    return marker in description.splitlines()


def broadcast_generation(broadcast: dict[str, Any]) -> str:
    description = str((broadcast.get("snippet") or {}).get("description") or "")
    marker_pattern = re.compile(rf"^\[{re.escape(GENERATION_MARKER_PREFIX)}:([A-Za-z0-9._-]+)\]$")
    generations = [
        match.group(1) for line in description.splitlines() if (match := marker_pattern.fullmatch(line)) is not None
    ]
    if len(generations) != 1:
        raise ReconciliationError("managed broadcast must contain exactly one generation marker")
    return generations[0]


def broadcast_lifecycle(broadcast: dict[str, Any]) -> str:
    return str((broadcast.get("status") or {}).get("lifeCycleStatus") or "")


def broadcast_privacy(broadcast: dict[str, Any]) -> str:
    return str((broadcast.get("status") or {}).get("privacyStatus") or "")


def broadcast_bound_stream(broadcast: dict[str, Any]) -> str:
    return str((broadcast.get("contentDetails") or {}).get("boundStreamId") or "")


def broadcast_by_id(broadcast_id: str) -> dict[str, Any] | None:
    data = api(
        "GET",
        "/liveBroadcasts",
        {"part": "id,snippet,contentDetails,status", "id": broadcast_id},
    )
    items = data.get("items") or []
    return items[0] if items else None


def list_broadcasts(status: str) -> list[dict[str, Any]]:
    items: list[dict[str, Any]] = []
    page_token = ""
    while True:
        params = {
            "part": "id,snippet,contentDetails,status",
            "broadcastStatus": status,
            "broadcastType": "event",
            "maxResults": "50",
        }
        if page_token:
            params["pageToken"] = page_token
        data = api("GET", "/liveBroadcasts", params)
        items.extend(item for item in data.get("items") or [] if isinstance(item, dict))
        page_token = str(data.get("nextPageToken") or "")
        if not page_token:
            return items


def list_managed_broadcasts(instance: str) -> list[dict[str, Any]]:
    marker = instance_marker(instance)
    matches: dict[str, dict[str, Any]] = {}
    for status in ("active", "upcoming"):
        for broadcast in list_broadcasts(status):
            broadcast_id = str(broadcast.get("id") or "")
            if broadcast_id and has_marker(broadcast, marker):
                matches[broadcast_id] = broadcast
    return list(matches.values())


def utc_now() -> str:
    return dt.datetime.now(dt.UTC).isoformat().replace("+00:00", "Z")


def lock_timeout() -> float:
    return float(os.environ.get("YTA_YOUTUBE_LOCK_TIMEOUT_SEC", "10"))


def lifecycle_state(
    previous: dict[str, Any],
    *,
    instance: str,
    generation: str,
    stream_id: str,
    broadcast: dict[str, Any] | None,
    pending_action: str | None,
    title: str,
    staging_privacy: str,
) -> dict[str, Any]:
    broadcast_id = str((broadcast or {}).get("id") or "")
    lifecycle = broadcast_lifecycle(broadcast or {})
    privacy = broadcast_privacy(broadcast or {}) or staging_privacy
    state = {
        "schema_version": STATE_SCHEMA_VERSION,
        "instance_id": instance,
        "generation_id": generation,
        "stream_id": stream_id,
        "broadcast_id": broadcast_id or None,
        "pending_action": pending_action,
        "last_known_lifecycle": lifecycle or None,
        "last_known_privacy": privacy,
        "title": title,
        "updated_at": utc_now(),
        "last_stream_id": stream_id,
        "last_broadcast_id": broadcast_id or None,
        "lifecycle": lifecycle or None,
        "privacy": privacy,
    }
    for key in ("retry_class", "retry_attempt", "retry_not_before"):
        if key in previous:
            state[key] = previous[key]
    return state


def validate_candidate(broadcast: dict[str, Any], *, instance: str, generation: str | None, stream_id: str) -> None:
    lifecycle = broadcast_lifecycle(broadcast)
    if lifecycle not in KNOWN_LIFECYCLE_STATES:
        raise ReconciliationError(f"unknown YouTube broadcast lifecycle: {lifecycle or '<empty>'}")
    if not has_marker(broadcast, instance_marker(instance)):
        raise ReconciliationError("cached broadcast did not match this encoder instance")
    candidate_generation = broadcast_generation(broadcast)
    if generation and candidate_generation != generation:
        raise ReconciliationError("cached broadcast did not match the persisted generation")
    bound_stream = broadcast_bound_stream(broadcast)
    if bound_stream and bound_stream != stream_id:
        raise ReconciliationError(f"managed broadcast is bound to a different stream: {bound_stream}")


def choose_candidate(
    broadcasts: list[dict[str, Any]], *, instance: str, generation: str | None, stream_id: str
) -> dict[str, Any] | None:
    if len(broadcasts) > 1:
        ids = ",".join(sorted(str(item.get("id") or "") for item in broadcasts))
        raise ReconciliationError(f"multiple managed broadcasts require operator reconciliation: {ids}")
    candidates = broadcasts
    if generation:
        marker = generation_marker(generation)
        candidates = [broadcast for broadcast in broadcasts if has_marker(broadcast, marker)]
        if broadcasts and not candidates:
            candidate_generation = str((broadcasts[0].get("snippet") or {}).get("description") or "")
            raise ReconciliationError(
                "managed broadcast generation conflicts with the persisted write-ahead generation: "
                f"{candidate_generation}"
            )
    if not candidates:
        return None
    candidate = candidates[0]
    validate_candidate(candidate, instance=instance, generation=generation, stream_id=stream_id)
    return candidate


def reconcile_broadcast(*, stream_id: str, title: str, staging_privacy: str, allow_create: bool) -> dict[str, Any]:
    with mutation_lock(timeout=lock_timeout()):
        instance = instance_id()
        state = read_state()
        if (
            state.get("schema_version") != STATE_SCHEMA_VERSION
            or state.get("instance_id") != instance
            or state.get("stream_id") != stream_id
        ):
            state = {}

        generation = str(state.get("generation_id") or "") or None
        broadcast: dict[str, Any] | None = None
        cached_id = str(state.get("broadcast_id") or state.get("last_broadcast_id") or "")
        if cached_id:
            cached = broadcast_by_id(cached_id)
            if cached is not None:
                validate_candidate(cached, instance=instance, generation=generation, stream_id=stream_id)
                if broadcast_lifecycle(cached) in RECOVERABLE_STATES:
                    broadcast = cached
                elif broadcast_lifecycle(cached) in TERMINAL_STATES:
                    state = {}
                    generation = None

        if broadcast is None:
            managed = list_managed_broadcasts(instance)
            broadcast = choose_candidate(
                managed,
                instance=instance,
                generation=generation,
                stream_id=stream_id,
            )

        if broadcast is None and not allow_create:
            raise ReconciliationError("no recoverable managed broadcast exists and creation is disabled")

        if broadcast is None:
            stream = stream_by_id(stream_id)
            stream_status_value = str((stream.get("status") or {}).get("streamStatus") or "")
            if stream_status_value != "active":
                raise ReconciliationError(
                    f"YouTube ingest must be active before broadcast creation; got {stream_status_value or 'unknown'}"
                )
            if generation is None:
                generation = str(uuid.uuid4())
                state = lifecycle_state(
                    state,
                    instance=instance,
                    generation=generation,
                    stream_id=stream_id,
                    broadcast=None,
                    pending_action="create",
                    title=title,
                    staging_privacy=staging_privacy,
                )
                write_state(state)

            exact = choose_candidate(
                list_managed_broadcasts(instance),
                instance=instance,
                generation=generation,
                stream_id=stream_id,
            )
            if exact is not None:
                broadcast = exact
            else:
                stream = stream_by_id(stream_id)
                stream_status_value = str((stream.get("status") or {}).get("streamStatus") or "")
                if stream_status_value != "active":
                    raise ReconciliationError(
                        f"YouTube ingest stopped before broadcast creation; got {stream_status_value or 'unknown'}"
                    )
                broadcast = create_broadcast(
                    title,
                    staging_privacy,
                    description=broadcast_description(instance, generation),
                )
                validate_candidate(broadcast, instance=instance, generation=generation, stream_id=stream_id)
                state = lifecycle_state(
                    state,
                    instance=instance,
                    generation=generation,
                    stream_id=stream_id,
                    broadcast=broadcast,
                    pending_action="bind",
                    title=title,
                    staging_privacy=staging_privacy,
                )
                write_state(state)

        validate_candidate(broadcast, instance=instance, generation=generation, stream_id=stream_id)
        if generation is None:
            generation = broadcast_generation(broadcast)
        if broadcast_bound_stream(broadcast) != stream_id:
            state = lifecycle_state(
                state,
                instance=instance,
                generation=generation,
                stream_id=stream_id,
                broadcast=broadcast,
                pending_action="bind",
                title=title,
                staging_privacy=staging_privacy,
            )
            write_state(state)
            broadcast = bind_broadcast(str(broadcast["id"]), stream_id)
            validate_candidate(broadcast, instance=instance, generation=generation, stream_id=stream_id)

        state = lifecycle_state(
            state,
            instance=instance,
            generation=generation,
            stream_id=stream_id,
            broadcast=broadcast,
            pending_action=None,
            title=title,
            staging_privacy=staging_privacy,
        )
        write_state(state)
        return state


def set_retry_state(retry_class: str, attempt: int, not_before: str) -> dict[str, Any]:
    if retry_class not in {"source", "api", "quota", "ambiguous"}:
        raise ValueError(f"unsupported retry class: {retry_class}")
    if attempt < 1:
        raise ValueError("retry attempt must be at least 1")
    with mutation_lock(timeout=lock_timeout()):
        state = read_state()
        state.setdefault("schema_version", STATE_SCHEMA_VERSION)
        state.setdefault("instance_id", instance_id())
        state.update(
            {
                "retry_class": retry_class,
                "retry_attempt": attempt,
                "retry_not_before": not_before,
                "updated_at": utc_now(),
            }
        )
        write_state(state)
        return state


def clear_retry_state() -> dict[str, Any]:
    with mutation_lock(timeout=lock_timeout()):
        state = read_state()
        for key in ("retry_class", "retry_attempt", "retry_not_before"):
            state.pop(key, None)
        state["updated_at"] = utc_now()
        write_state(state)
        return state


def create_broadcast(title: str, privacy: str, description: str | None = None) -> dict[str, Any]:
    start_time = (dt.datetime.now(dt.UTC) + dt.timedelta(minutes=1)).isoformat().replace("+00:00", "Z")
    body = {
        "snippet": {
            "title": title,
            "description": description or "Started by YouTube AutoEncoder.",
            "scheduledStartTime": start_time,
        },
        "contentDetails": {
            "enableDvr": True,
            "recordFromStart": True,
            "enableAutoStart": False,
            "enableAutoStop": False,
            "monitorStream": {"enableMonitorStream": True},
        },
        "status": {
            "privacyStatus": privacy,
            "selfDeclaredMadeForKids": False,
        },
    }
    return api("POST", "/liveBroadcasts", {"part": "snippet,contentDetails,status"}, body)


def bind_broadcast(broadcast_id: str, stream_id: str) -> dict[str, Any]:
    return api(
        "POST",
        "/liveBroadcasts/bind",
        {"part": "id,snippet,contentDetails,status", "id": broadcast_id, "streamId": stream_id},
    )


def stream_status(stream_id: str | None = None) -> dict[str, Any]:
    stream = stream_by_id(stream_id) if stream_id else ensure_stream(create_if_missing=False)
    status = stream.get("status") or {}
    health = status.get("healthStatus") or {}
    return {
        "stream_id": stream.get("id"),
        "stream_title": (stream.get("snippet") or {}).get("title"),
        "stream_status": status.get("streamStatus"),
        "health": health.get("status"),
        "configuration_issues": health.get("configurationIssues") or [],
    }


def broadcast_status(broadcast_id: str) -> dict[str, Any]:
    broadcast = broadcast_by_id(broadcast_id)
    if broadcast is None:
        raise ReconciliationError(f"liveBroadcast not found: {broadcast_id}")
    return {
        "broadcast_id": broadcast.get("id"),
        "title": (broadcast.get("snippet") or {}).get("title"),
        "scheduled_start_time": (broadcast.get("snippet") or {}).get("scheduledStartTime"),
        "lifecycle": broadcast_lifecycle(broadcast),
        "privacy": broadcast_privacy(broadcast),
        "bound_stream_id": broadcast_bound_stream(broadcast),
    }


def set_broadcast_privacy(broadcast_id: str, privacy: str) -> dict[str, Any]:
    current = broadcast_by_id(broadcast_id)
    if current is None:
        raise ReconciliationError(f"liveBroadcast not found: {broadcast_id}")
    snippet = current.get("snippet") or {}
    content_details = current.get("contentDetails") or {}
    monitor = content_details.get("monitorStream") or {}
    status = current.get("status") or {}
    scheduled_start = snippet.get("scheduledStartTime")
    if not scheduled_start:
        raise ReconciliationError("broadcast has no scheduledStartTime required for privacy update")
    body = {
        "id": broadcast_id,
        "snippet": {"scheduledStartTime": scheduled_start},
        "contentDetails": {
            "monitorStream": {
                "enableMonitorStream": bool(monitor.get("enableMonitorStream", True)),
                "broadcastStreamDelayMs": int(monitor.get("broadcastStreamDelayMs") or 0),
            }
        },
        "status": {
            "privacyStatus": privacy,
            "selfDeclaredMadeForKids": bool(status.get("selfDeclaredMadeForKids", False)),
        },
    }
    api("PUT", "/liveBroadcasts", {"part": "status"}, body)
    verified = broadcast_by_id(broadcast_id)
    if verified is None or broadcast_privacy(verified) != privacy:
        actual = broadcast_privacy(verified or {}) or "missing"
        raise ReconciliationError(f"privacy update verification failed: expected {privacy}, got {actual}")
    return verified


def stream_by_id(stream_id: str) -> dict[str, Any]:
    data = api("GET", "/liveStreams", {"part": "id,snippet,cdn,status,contentDetails", "id": stream_id})
    items = data.get("items") or []
    if not items:
        raise LookupError(f"liveStream not found: {stream_id}")
    return items[0]


def wait_stream_active(stream_id: str, timeout: int) -> dict[str, Any]:
    deadline = time.monotonic() + timeout
    last = None
    while time.monotonic() < deadline:
        stream = stream_by_id(stream_id)
        stream_status = (stream.get("status") or {}).get("streamStatus")
        if stream_status == "active":
            return stream
        if stream_status != last:
            log(f"YouTube stream status={stream_status}")
            last = stream_status
        time.sleep(5)
    raise TimeoutError(f"stream {stream_id} did not become active within {timeout}s")


def transition(broadcast_id: str, status: str) -> dict[str, Any]:
    return api(
        "POST",
        "/liveBroadcasts/transition",
        {"part": "id,snippet,contentDetails,status", "id": broadcast_id, "broadcastStatus": status},
    )


def write_state(data: dict[str, Any]) -> None:
    write_secret_json(STATE_FILE, data)


def prepare_broadcast(args: argparse.Namespace) -> int:
    stream = ensure_stream(create_if_missing=args.create_stream)
    stream_id = str(stream["id"])
    title = args.title or f"{args.title_prefix} {dt.datetime.now().strftime('%Y-%m-%d %H:%M')}"
    state = reconcile_broadcast(
        stream_id=stream_id,
        title=title,
        staging_privacy=args.privacy,
        allow_create=True,
    )
    print(json.dumps(state, indent=2, sort_keys=True))
    return 0


def wait_active_command(args: argparse.Namespace) -> int:
    state = read_state()
    stream_id = args.stream_id or str(state.get("stream_id") or state.get("last_stream_id") or "")
    if not stream_id:
        raise ValueError("no stream id provided and no previous state file found")
    stream = wait_stream_active(stream_id, args.timeout)
    print(
        json.dumps(
            {
                "stream_id": stream.get("id"),
                "stream_status": ((stream.get("status") or {}).get("streamStatus")),
                "health": (((stream.get("status") or {}).get("healthStatus") or {}).get("status")),
            },
            indent=2,
            sort_keys=True,
        )
    )
    return 0


def status(_args: argparse.Namespace) -> int:
    print(json.dumps(stream_status(), indent=2, sort_keys=True))
    return 0


def state_command(_args: argparse.Namespace) -> int:
    print(json.dumps(read_state(), indent=2, sort_keys=True))
    return 0


def reconcile_command(args: argparse.Namespace) -> int:
    stream = ensure_stream(create_if_missing=args.create_stream)
    stream_id = str(stream["id"])
    title = args.title or f"{args.title_prefix} {dt.datetime.now().strftime('%Y-%m-%d %H:%M')}"
    state = reconcile_broadcast(
        stream_id=stream_id,
        title=title,
        staging_privacy=args.privacy,
        allow_create=args.allow_create,
    )
    print(json.dumps(state, indent=2, sort_keys=True))
    return 0


def stream_status_command(args: argparse.Namespace) -> int:
    print(json.dumps(stream_status(args.stream_id), indent=2, sort_keys=True))
    return 0


def broadcast_status_command(args: argparse.Namespace) -> int:
    state = read_state()
    broadcast_id = args.broadcast_id or str(state.get("broadcast_id") or state.get("last_broadcast_id") or "")
    if not broadcast_id:
        raise ValueError("no broadcast id provided and no previous state file found")
    print(json.dumps(broadcast_status(broadcast_id), indent=2, sort_keys=True))
    return 0


def set_privacy_command(args: argparse.Namespace) -> int:
    with mutation_lock(timeout=lock_timeout()):
        state = read_state()
        broadcast_id = args.broadcast_id or str(state.get("broadcast_id") or state.get("last_broadcast_id") or "")
        if not broadcast_id:
            raise ValueError("no broadcast id provided and no previous state file found")
        result = set_broadcast_privacy(broadcast_id, args.privacy)
        state.update(
            {
                "broadcast_id": broadcast_id,
                "last_broadcast_id": broadcast_id,
                "last_known_lifecycle": broadcast_lifecycle(result) or None,
                "last_known_privacy": broadcast_privacy(result),
                "lifecycle": broadcast_lifecycle(result) or None,
                "privacy": broadcast_privacy(result),
                "updated_at": utc_now(),
            }
        )
        write_state(state)
    print(json.dumps(broadcast_status(broadcast_id), indent=2, sort_keys=True))
    return 0


def set_retry_command(args: argparse.Namespace) -> int:
    state = set_retry_state(args.retry_class, args.attempt, args.retry_not_before)
    print(json.dumps(state, indent=2, sort_keys=True))
    return 0


def clear_retry_command(_args: argparse.Namespace) -> int:
    print(json.dumps(clear_retry_state(), indent=2, sort_keys=True))
    return 0


def stop_child(signum: int, _frame: Any) -> None:
    global stopping
    stopping = True
    if child and child.poll() is None:
        log(f"received signal {signum}; stopping test pattern")
        child.send_signal(signal.SIGINT)


def run_visible_test(args: argparse.Namespace) -> int:
    global child
    stream = ensure_stream(create_if_missing=args.create_stream)
    stream_id = str(stream["id"])
    title = args.title or f"AutoEncoder Test Pattern {dt.datetime.now().strftime('%Y-%m-%d %H:%M')}"
    child = subprocess.Popen(
        [os.environ.get("YTA_TEST_PATTERN", "youtube-autoencoder-test-pattern"), str(args.duration)],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
    )
    selector = selectors.DefaultSelector()
    if child.stdout is not None:
        selector.register(child.stdout, selectors.EVENT_READ)
    try:
        wait_stream_active(stream_id, args.wait_stream_active)
        state = reconcile_broadcast(
            stream_id=stream_id,
            title=title,
            staging_privacy=args.privacy,
            allow_create=True,
        )
        broadcast_id = str(state["broadcast_id"])
        lifecycle = str(state.get("lifecycle") or "")
        log(f"reconciled broadcast id={broadcast_id} stream_id={stream_id} lifecycle={lifecycle}")

        if lifecycle in {"created", "ready"}:
            with mutation_lock(timeout=lock_timeout()):
                transitioned = transition(broadcast_id, "testing")
            lifecycle = str((transitioned.get("status") or {}).get("lifeCycleStatus") or "")
            log(f"transitioned broadcast to testing status={lifecycle}")
        if lifecycle in {"created", "ready", "testStarting", "testing"}:
            time.sleep(args.testing_delay)
            with mutation_lock(timeout=lock_timeout()):
                transitioned = transition(broadcast_id, "live")
            lifecycle = str((transitioned.get("status") or {}).get("lifeCycleStatus") or "")
            log(f"transitioned broadcast to live status={lifecycle}")
        while child.poll() is None and not stopping:
            for key, _mask in selector.select(timeout=1):
                line = key.fileobj.readline()
                if line:
                    print(line.rstrip(), flush=True)
        rc = child.wait(timeout=20)
        if args.complete:
            with mutation_lock(timeout=lock_timeout()):
                current = broadcast_by_id(broadcast_id)
                if current is None or broadcast_lifecycle(current) != "live":
                    actual = broadcast_lifecycle(current or {}) or "missing"
                    raise ReconciliationError(
                        f"refusing explicit completion because broadcast is not confirmed live: {actual}"
                    )
                transition(broadcast_id, "complete")
            log("completed YouTube broadcast after explicit --complete request")
        return rc
    finally:
        if child and child.poll() is None:
            log("stopping test pattern after interrupted API test")
            child.send_signal(signal.SIGINT)
            try:
                child.wait(timeout=20)
            except subprocess.TimeoutExpired:
                log("test pattern did not stop cleanly; killing")
                child.kill()
                child.wait(timeout=10)
        selector.close()
        child = None


def complete(args: argparse.Namespace) -> int:
    with mutation_lock(timeout=lock_timeout()):
        state = read_state()
        broadcast_id = args.broadcast_id or str(state.get("broadcast_id") or state.get("last_broadcast_id") or "")
        if not broadcast_id:
            raise ValueError("no broadcast id provided and no previous state file found")
        current = broadcast_by_id(broadcast_id)
        lifecycle = broadcast_lifecycle(current or {})
        if current is None or lifecycle != "live":
            raise ReconciliationError(
                f"refusing completion because broadcast is not confirmed live: {lifecycle or 'missing'}"
            )
        result = transition(broadcast_id, "complete")
    print(json.dumps({"id": result.get("id"), "status": result.get("status")}, indent=2, sort_keys=True))
    return 0


def transition_command(args: argparse.Namespace) -> int:
    with mutation_lock(timeout=lock_timeout()):
        state = read_state()
        broadcast_id = args.broadcast_id or str(state.get("broadcast_id") or state.get("last_broadcast_id") or "")
        if not broadcast_id:
            raise ValueError("no broadcast id provided and no previous state file found")
        result = transition(broadcast_id, args.status)
    print(json.dumps({"id": result.get("id"), "status": result.get("status")}, indent=2, sort_keys=True))
    return 0


def main() -> int:
    signal.signal(signal.SIGTERM, stop_child)
    signal.signal(signal.SIGINT, stop_child)
    parser = argparse.ArgumentParser(description="Control YouTube Live for YouTube AutoEncoder")
    sub = parser.add_subparsers(dest="command", required=True)

    auth_p = sub.add_parser("authorize", help="Run OAuth device authorization")
    auth_p.set_defaults(func=authorize)

    status_p = sub.add_parser("status", help="Show the liveStream matching OBS service.json")
    status_p.set_defaults(func=status)

    state_p = sub.add_parser("state", help="Show non-secret persisted lifecycle state")
    state_p.set_defaults(func=state_command)

    stream_status_p = sub.add_parser("stream-status", help="Show reusable liveStream ingest status")
    stream_status_p.add_argument("stream_id", nargs="?")
    stream_status_p.set_defaults(func=stream_status_command)

    broadcast_status_p = sub.add_parser("broadcast-status", help="Show managed liveBroadcast status")
    broadcast_status_p.add_argument("broadcast_id", nargs="?")
    broadcast_status_p.set_defaults(func=broadcast_status_command)

    prepare_p = sub.add_parser("prepare-broadcast", help="Create and bind a broadcast for the reusable stream")
    prepare_p.add_argument(
        "--privacy",
        choices=["public", "unlisted", "private"],
        default=os.environ.get("YTA_YOUTUBE_PRIVACY", "unlisted"),
    )
    prepare_p.add_argument("--title")
    prepare_p.add_argument("--title-prefix", default=os.environ.get("YTA_YOUTUBE_TITLE_PREFIX", "AutoEncoder Live"))
    prepare_p.add_argument(
        "--create-stream", action="store_true", help="Create a reusable stream if OBS key is not found"
    )
    prepare_p.set_defaults(func=prepare_broadcast)

    reconcile_p = sub.add_parser(
        "reconcile-broadcast", help="Recover or create one managed broadcast for the reusable stream"
    )
    reconcile_p.add_argument(
        "--privacy",
        choices=["public", "unlisted", "private"],
        default=os.environ.get("YTA_YOUTUBE_PRIVACY", "unlisted"),
    )
    reconcile_p.add_argument("--title")
    reconcile_p.add_argument("--title-prefix", default=os.environ.get("YTA_YOUTUBE_TITLE_PREFIX", "AutoEncoder Live"))
    reconcile_p.add_argument(
        "--create-stream", action="store_true", help="Create a reusable stream if OBS key is not found"
    )
    reconcile_p.add_argument(
        "--allow-create",
        action="store_true",
        help="Permit one new broadcast only after ingest is active and reconciliation is unambiguous",
    )
    reconcile_p.set_defaults(func=reconcile_command)

    wait_p = sub.add_parser("wait-stream-active", help="Wait until a liveStream reports active ingest")
    wait_p.add_argument("stream_id", nargs="?")
    wait_p.add_argument("--timeout", type=int, default=int(os.environ.get("YTA_YOUTUBE_WAIT_ACTIVE_SEC", "180")))
    wait_p.set_defaults(func=wait_active_command)

    test_p = sub.add_parser("run-visible-test", help="Create/bind/transition a visible test-pattern broadcast")
    test_p.add_argument("--duration", type=int, default=900)
    test_p.add_argument("--wait-stream-active", type=int, default=120)
    test_p.add_argument("--testing-delay", type=int, default=8)
    test_p.add_argument(
        "--privacy",
        choices=["public", "unlisted", "private"],
        default=os.environ.get("YTA_YOUTUBE_PRIVACY", "unlisted"),
    )
    test_p.add_argument("--title")
    test_p.add_argument("--create-stream", action="store_true", help="Create a reusable stream if OBS key is not found")
    test_p.add_argument(
        "--complete",
        action="store_true",
        help="Explicitly complete the known broadcast after confirming it is live",
    )
    test_p.add_argument("--no-complete", dest="complete", action="store_false", help=argparse.SUPPRESS)
    test_p.set_defaults(func=run_visible_test, complete=False)

    complete_p = sub.add_parser("complete", help="Complete the last or specified broadcast")
    complete_p.add_argument("broadcast_id", nargs="?")
    complete_p.set_defaults(func=complete)

    transition_p = sub.add_parser("transition", help="Transition the last or specified broadcast")
    transition_p.add_argument("status", choices=["testing", "live"])
    transition_p.add_argument("broadcast_id", nargs="?")
    transition_p.set_defaults(func=transition_command)

    privacy_p = sub.add_parser("set-privacy", help="Update and verify broadcast visibility")
    privacy_p.add_argument("privacy", choices=["public", "unlisted", "private"])
    privacy_p.add_argument("broadcast_id", nargs="?")
    privacy_p.set_defaults(func=set_privacy_command)

    retry_p = sub.add_parser("set-retry", help="Persist a classified recovery deadline")
    retry_p.add_argument("retry_class", choices=["source", "api", "quota", "ambiguous"])
    retry_p.add_argument("attempt", type=int)
    retry_p.add_argument("retry_not_before")
    retry_p.set_defaults(func=set_retry_command)

    clear_retry_p = sub.add_parser("clear-retry", help="Clear persisted recovery backoff")
    clear_retry_p.set_defaults(func=clear_retry_command)

    args = parser.parse_args()
    return int(args.func(args))


def cli_main() -> int:
    try:
        return main()
    except KeyboardInterrupt:
        return 130
    except Exception as exc:  # noqa: BLE001
        payload = error_payload(exc)
        print(json.dumps(payload, sort_keys=True), file=sys.stderr)
        return 75 if payload["retry_class"] in {"api", "quota"} else 78


if __name__ == "__main__":
    sys.exit(cli_main())
